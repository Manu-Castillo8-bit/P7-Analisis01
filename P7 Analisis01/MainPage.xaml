<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P7_Analisis01.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="https://drive.google.com/file/d/1udM3n2ne-42ijTOperKVL7-SyMfF_XgP/view?usp=sharing"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="Manuelito Castillo" />

            <Label
                Text="NOMBRE: Mi nombre es Manuel Ernesto Castillo Guerra"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="DIRECCIÓN: Vivo frente a la Colonia Sagrado Corazón, Palos Grandes, Lourdes, Colón"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level1" />

             <Label
                Text="N° DE TELÉFONO: 7933-7083"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="CORREO ELECTRÓNICO: ernesto.ccastillo2@gmail.com"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
